              "",
              "",
              "pm.test(\"firstname is correct\", function () {",
              "    // pm.expect(firstName_actual).to.eql(\"Jim\");",
              "    pm.expect(getResponse.booking.firstname).to.eql(ExpectedFirstName);",
              "});",
              "",
              "pm.test(\"lastname is correct\", function () {",
