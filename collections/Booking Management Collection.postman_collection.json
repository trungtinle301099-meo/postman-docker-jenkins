    {
      "name": "01_Auth",
      "item": [
        {
          "name": "Auth - CreateToken",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Validate required environment variables",
                  "const requiredEnvVars = ['URL'];",
                  "",
                  "requiredEnvVars.forEach((key) => {",
                  "  const value = pm.environment.get(key);",
                  "",
                  "  if (!value) {",
                  "    throw new Error(`Missing required environment variable: ${key}`);",
                  "  }",
                  "});",
                  "",
                  "// Generate dynamic tracking data for this auth request",
                  "const timestamp = Date.now();",
                  "const randomNumber = Math.floor(100000 + Math.random() * 900000);",
                  "",
                  "const authRequestId = `AUTH_${timestamp}_${randomNumber}`;",
                  "const authRequestedAt = new Date().toISOString();",
                  "",
                  "pm.environment.set('authRequestId', authRequestId);",
                  "pm.environment.set('authRequestedAt', authRequestedAt);",
                  "",
                  "// Clear old auth data before requesting a new token",
                  "pm.environment.unset('authToken');",
                  "pm.environment.unset('authCookie');"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code should be 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time should be acceptable', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "pm.test('Response should be valid JSON', function () {",
                  "  pm.response.to.be.json;",
                  "});",
                  "",
                  "let jsonData = {};",
                  "",
                  "pm.test('Response body should be parsed safely', function () {",
                  "  try {",
                  "    jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('object');",
                  "  } catch (error) {",
                  "    throw new Error(`Response is not valid JSON: ${error.message}`);",
                  "  }",
                  "});",
                  "",
                  "pm.test('Response should contain token', function () {",
                  "  pm.expect(jsonData).to.have.property('token');",
                  "  pm.expect(jsonData.token).to.be.a('string');",
                  "  pm.expect(jsonData.token.trim()).to.not.be.empty;",
                  "});",
                  "",
                  "if (jsonData && typeof jsonData.token === 'string' && jsonData.token.trim()) {",
                  "  const token = jsonData.token.trim();",
                  "",
                  "  pm.environment.set('authToken', token);",
                  "  pm.environment.set('authCookie', `token=${token}`);",
                  "}",
                  "",
                  "pm.test('Auth token should be saved to environment', function () {",
                  "  pm.expect(pm.environment.get('authToken')).to.be.a('string');",
                  "  pm.expect(pm.environment.get('authToken')).to.not.be.empty;",
                  "});",
                  "",
                  "pm.test('Auth cookie should be prepared for protected booking APIs', function () {",
                  "  pm.expect(pm.environment.get('authCookie')).to.eql(`token=${pm.environment.get('authToken')}`);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
