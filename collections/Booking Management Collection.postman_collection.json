                  "pm.environment.set('updateBookingRequestId', `UPDATE_BOOKING_${timestamp}_${bookingId}`);",
                  "pm.environment.set('updateFirstname', `UpdatedFirst${randomNumber}`);",
                  "pm.environment.set('updateLastname', `UpdatedLast${timestamp}`);",
                  "pm.environment.set('updateTotalPrice', String(Math.floor(200 + Math.random() * 800)));",
                  "pm.environment.set('updateDepositPaid', String(Math.random() >= 0.5));",
                  "pm.environment.set('updateCheckinDate', formatDate(checkinDate));",
                  "pm.environment.set('updateCheckoutDate', formatDate(checkoutDate));",
                  "pm.environment.set('updateAdditionalNeeds', `Updated Breakfast ${randomNumber}`);"
