                  "});",
                  "",
                  "const bookingId = pm.environment.get('bookingId');",
                  "const createdBookingId = pm.environment.get('createdBookingId');",
                  "",
                  "if (bookingId !== createdBookingId) {",
                  "  throw new Error(",
                  "    `bookingId mismatch. UpdateBooking must use bookingId from CreateBooking. bookingId=${bookingId}, createdBookingId=${createdBookingId}`",
                  "  );",
                  "}",
                  "",
                  "if (!/^\\d+$/.test(bookingId)) {",
                  "  throw new Error(`Invalid bookingId. Expected positive number but got: ${bookingId}`);",
                  "}",
